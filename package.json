{
  "name": "hubfit-mvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "tsx watch scripts/dev.ts",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "tsc --project tsconfig.json --noEmit",
    "typecheck:server": "tsc --project tsconfig.server.json --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.8",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-popover": "^1.1.20",
    "@radix-ui/react-progress": "^1.1.13",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-toggle": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "kysely": "^0.29.4",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5"
