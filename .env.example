NODE_ENV=development
PORT=3001

# Comma-separated browser origins allowed to call the API.
# In production, omit this only when the client and API share the same origin.
CLIENT_ORIGIN=http://localhost:3000

# Express request and rate limits.
MAX_REQUEST_SIZE=32kb
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Demo accounts are never seeded in production unless explicitly enabled.
SEED_DEMO_DATA=false

# Required in production. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Development creates a local ignored key under data/ when this is left blank.
MFA_ENCRYPTION_KEY=

# Optional official distribution links. Only HTTPS URLs are exposed by the API.
DOWNLOAD_WINDOWS_URL=
DOWNLOAD_ANDROID_URL=
DOWNLOAD_MACOS_URL=
DOWNLOAD_IOS_URL=
DOWNLOAD_ZIP_URL=
